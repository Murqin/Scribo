# Telegram Bot Token (BotFather'dan alınan token)
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Botu sadece sizin kullanmanız için Telegram ID'niz (@userinfobot'tan öğrenebilirsiniz)
ALLOWED_USER_ID=123456789

# AI Sağlayıcı API Anahtarları
GEMINI_API_KEY=AIzaSy...
OPENROUTER_API_KEY=sk-or-v1-...

# Varsayılan AI Sağlayıcısı (google veya openrouter)
DEFAULT_PROVIDER=google

# Modeller
GOOGLE_MODEL=gemini-3.6-flash
OPENROUTER_MODEL=google/gemini-3.6-flash
