# --------------------------------------------------
# Scribo Telegram Bot Yapılandırma Dosyası (.env)
# --------------------------------------------------

# 1. Telegram Bot Token (BotFather'dan alınan token)
# Örnek: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_TOKEN=your_telegram_bot_token_here

# 2. Yetkili Telegram Kullanıcı ID'si
# Botu sadece sizin kullanabilmeniz için sayısal Telegram ID'niz (@userinfobot'tan öğrenebilirsiniz).
# Herkese açık yapmak isterseniz boş bırakın.
ALLOWED_USER_ID=your_telegram_id_here

# 3. Google AI Studio API Anahtarı (Free Tier / Ücretsiz)
# https://aistudio.google.com/ adresinden ücretsiz alınabilir.
GEMINI_API_KEY=your_google_gemini_api_key_here

# 4. OpenRouter API Anahtarı (Yedek / Ücretli Kullanım)
# https://openrouter.ai/ adresinden alınabilir.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 5. Varsayılan AI Sağlayıcısı (google veya openrouter)
DEFAULT_PROVIDER=google

# 6. Kullanılacak AI Modelleri
GOOGLE_MODEL=gemini-3.6-flash
OPENROUTER_MODEL=google/gemini-3.6-flash

# 7. Eşzamanlı İşlem Limiti (Aynı anda işlenebilecek maksimum ses dosyası sayısı)
# Sunucunun aşırı yüklenmesini ve API limitlerine takılmayı önlemek için Semafor Worker Pool kullanır.
# Belirtilen sayıdan fazla istek geldiğinde (Örn: 5), fazla istekler sıraya alınır ve güvenle beklenir.
MAX_CONCURRENT_JOBS=5
