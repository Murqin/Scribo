# ==============================================================================
# Whitelisted .gitignore Strategy
# Block everything by default; explicitly whitelist only essential source files.
# ==============================================================================

# 1. Ignore everything by default
*
!*/

# 2. Whitelist project configuration & metadata
!.gitignore
!LICENSE
!Makefile
!README.md
!go.mod
!go.sum

# 3. Whitelist configuration templates
!.env.example
!modes.example.json

# 4. Whitelist source code & embedded assets
!main.go
!bot/
!bot/*.go
!config/
!config/*.go
!mode/
!mode/*.go
!mode/default_modes.json
!provider/
!provider/*.go

# 5. Whitelist repository assets & GitHub CI/CD workflows
!assets/
!assets/**
!.github/
!.github/**

# 6. Whitelist production deployment scripts
!setup_service.sh
!setup_keepalive.sh
!restart.sh
!stop.sh
!uninstall.sh
